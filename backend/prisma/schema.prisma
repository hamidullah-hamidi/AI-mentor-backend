generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ProjectStatus {
  DRAFT
  IN_REVIEW
  READY
  ARCHIVED
}

enum ManuscriptType {
  CASE_REPORT
}

model Journal {
  id              String         @id @default(cuid())
  code            String         @unique
  name            String         @unique
  publisher       String?
  description     String?
  manuscriptType  ManuscriptType @default(CASE_REPORT)
  guidelinePackId String?
  guidelinePack   GuidelinePack? @relation(fields: [guidelinePackId], references: [id], onDelete: Cascade)
  isDefault       Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  sectionTemplates JournalSectionTemplate[]
  projects         Project[]

  @@index([isDefault])
  @@map("journals")
}

model JournalSectionTemplate {
  id             String                 @id @default(cuid())
  journalId      String
  key            String
  title          String
  sectionOrder   Int
  isOptional     Boolean                @default(false)
  description    String 
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)

  @@unique([journalId, key])
  @@index([journalId, sectionOrder])
  @@map("journal_section_templates")
}



enum SectionStatus {
  NOT_STARTED
  DRAFT
  IN_REVIEW
  READY
}

enum ReviewRunStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  RESOLVED
  IGNORED
}

enum ReadinessStatus {
  NOT_READY
  NEEDS_ATTENTION
  READY_FOR_INTERNAL_REVIEW
  READY_FOR_SUBMISSION
}

enum GuidelinePackStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PromptTemplateType {
  SECTION_REVIEW
  SYSTEM_GUARDRAIL
  FOLLOW_UP
}

enum PromptTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PlanBillingModel {
  FREE
  MONTHLY
  CREDIT_PACK
  HYBRID
}

enum SubscriptionPlanStatus {
  ACTIVE
  ARCHIVED
}

enum UserSubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  TRIALING
}

enum CreditTransactionType {
  ALLOCATION
  DEDUCTION
  ADJUSTMENT
  EXPIRY
  REFUND
  PURCHASE
}

enum CreditTransactionSource {
  SUBSCRIPTION
  AI_REVIEW
  ADMIN_ADJUSTMENT
  PURCHASE
  MANUAL
}

enum AiProvider {
  OPENAI
}

enum AiUsageStatus {
  SUCCESS
  FAILED
  SKIPPED
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  fullName           String
  role               Role                @default(USER)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  projects           Project[]
  refreshTokens      RefreshToken[]
  sectionVersions    SectionVersion[]
  initiatedReviews   ReviewRun[]         @relation("ReviewInitiator")
  resolvedIssues     ReviewIssue[]       @relation("IssueResolver")
  subscriptions      UserSubscription[]
  creditWallet       CreditWallet?
  creditTransactions CreditTransaction[]
  aiUsageLogs        AiUsageLog[]
  auditLogs          AuditLog[]          @relation("AuditActor")

  @@index([role, isActive])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Project {
  id                 String              @id @default(cuid())
  ownerId            String
  manuscriptType     ManuscriptType      @default(CASE_REPORT)
  title              String
  status             ProjectStatus       @default(DRAFT)
  targetJournal      String?
  metadata           Json?
  readinessScore     Int?
  lastReviewedAt     DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  owner              User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sections           ProjectSection[]
  reviewRuns         ReviewRun[]
  reviewIssues       ReviewIssue[]
  readinessSnapshots ReadinessSnapshot[]
  aiUsageLogs        AiUsageLog[]
  journalId          String?
  journal            Journal?            @relation(fields: [journalId], references: [id], onDelete: SetNull)

  @@index([ownerId, updatedAt])
  @@index([status])
  @@index([journalId])
}

model ProjectSection {
  id           String            @id @default(cuid())
  projectId    String
  key          String
  title        String
  content      String            @default("")
  sectionOrder Int
  isOptional   Boolean           @default(false)
  status       SectionStatus     @default(NOT_STARTED)
  lastEditedAt DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions     SectionVersion[]
  reviewRuns   ReviewRun[]
  issues       ReviewIssue[]

  @@unique([projectId, key])
  @@index([projectId, sectionOrder])
}

model SectionVersion {
  id            String         @id @default(cuid())
  sectionId     String
  versionNumber Int
  content       String
  changeSummary String?
  editedById    String
  createdAt     DateTime       @default(now())
  section       ProjectSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  editedBy      User           @relation(fields: [editedById], references: [id], onDelete: Restrict)

  @@unique([sectionId, versionNumber])
  @@index([editedById, createdAt])
}

model ReviewRun {
  id                   String              @id @default(cuid())
  projectId            String
  sectionId            String
  initiatedById        String
  promptTemplateId     String?
  guidelinePackId      String?
  aiProvider           AiProvider          @default(OPENAI)
  aiModel              String
  status               ReviewRunStatus     @default(QUEUED)
  summary              String?
  nextSteps            Json?
  missingInfoQuestions Json?
  warnings             Json?
  overallScore         Int?
  readinessIndicator   Int?
  rawResponse          Json?
  errorMessage         String?
  inputTokens          Int?
  outputTokens         Int?
  totalTokens          Int?
  appCreditsConsumed   Int                 @default(0)
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  project              Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  section              ProjectSection      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  initiatedBy          User                @relation("ReviewInitiator", fields: [initiatedById], references: [id], onDelete: Restrict)
  issues               ReviewIssue[]
  suggestions          ReviewSuggestion[]
  metrics              ReviewMetric[]
  usageLog             AiUsageLog?
  promptTemplate       PromptTemplate?     @relation(fields: [promptTemplateId], references: [id], onDelete: SetNull)
  guidelinePack        GuidelinePack?      @relation(fields: [guidelinePackId], references: [id], onDelete: SetNull)
  creditTransactions   CreditTransaction[]

  @@index([projectId, createdAt])
  @@index([sectionId, createdAt])
  @@index([status])
}

model ReviewIssue {
  id            String         @id @default(cuid())
  reviewRunId   String
  projectId     String
  sectionId     String
  severity      IssueSeverity
  category      String
  title         String
  description   String
  reason        String
  fixSuggestion String
  status        IssueStatus    @default(OPEN)
  resolvedAt    DateTime?
  resolvedById  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  reviewRun     ReviewRun      @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  section       ProjectSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  resolvedBy    User?          @relation("IssueResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([projectId, status, severity])
  @@index([sectionId, status])
}

model ReviewSuggestion {
  id          String    @id @default(cuid())
  reviewRunId String
  type        String
  title       String
  content     String
  createdAt   DateTime  @default(now())
  reviewRun   ReviewRun @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)

  @@index([reviewRunId])
}

model ReviewMetric {
  id          String    @id @default(cuid())
  reviewRunId String
  name        String
  score       Int
  weight      Int?
  rationale   String?
  createdAt   DateTime  @default(now())
  reviewRun   ReviewRun @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)

  @@index([reviewRunId])
}

model ReadinessSnapshot {
  id            String          @id @default(cuid())
  projectId     String
  overallScore  Int
  status        ReadinessStatus
  summary       String
  blockers      Json?
  strengths     Json?
  sectionScores Json?
  createdAt     DateTime        @default(now())
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model GuidelinePack {
  id             String              @id @default(cuid())
  name           String
  code           String              @unique
  version        String
  description    String?
  manuscriptType ManuscriptType      @default(CASE_REPORT)
  status         GuidelinePackStatus @default(DRAFT)
  rules          Json
  isDefault      Boolean             @default(false)
  createdById    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  archivedAt     DateTime?
  reviewRuns     ReviewRun[]

  @@index([status, isDefault])
}

model PromptTemplate {
  id             String               @id @default(cuid())
  name           String
  code           String               @unique
  description    String?
  type           PromptTemplateType
  version        Int                  @default(1)
  status         PromptTemplateStatus @default(DRAFT)
  templateText   String
  responseSchema Json?
  config         Json?
  createdById    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  archivedAt     DateTime?
  reviewRuns     ReviewRun[]

  @@index([type, status])
}

model SubscriptionPlan {
  id                      String                 @id @default(cuid())
  name                    String
  code                    String                 @unique
  description             String?
  billingModel            PlanBillingModel
  monthlyPriceCents       Int?
  includedCredits         Int                    @default(0)
  overageCreditPriceCents Int?
  features                Json?
  status                  SubscriptionPlanStatus @default(ACTIVE)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  subscriptions           UserSubscription[]

  @@index([status, billingModel])
}

model UserSubscription {
  id                 String                 @id @default(cuid())
  userId             String
  subscriptionPlanId String
  status             UserSubscriptionStatus @default(ACTIVE)
  startedAt          DateTime               @default(now())
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  autoRenew          Boolean                @default(true)
  externalReference  String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionPlan   SubscriptionPlan       @relation(fields: [subscriptionPlanId], references: [id], onDelete: Restrict)

  @@index([userId, status, currentPeriodEnd])
}

model CreditWallet {
  id                      String              @id @default(cuid())
  userId                  String              @unique
  balance                 Int                 @default(0)
  lifetimeCreditsGranted  Int                 @default(0)
  lifetimeCreditsConsumed Int                 @default(0)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  user                    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions            CreditTransaction[]

  @@index([balance])
}

model CreditTransaction {
  id                 String                  @id @default(cuid())
  walletId           String
  userId             String
  type               CreditTransactionType
  source             CreditTransactionSource
  amount             Int
  balanceAfter       Int
  description        String?
  relatedReviewRunId String?
  metadata           Json?
  createdAt          DateTime                @default(now())
  wallet             CreditWallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewRun          ReviewRun?              @relation(fields: [relatedReviewRunId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([relatedReviewRunId])
}

model AiUsageLog {
  id                    String        @id @default(cuid())
  userId                String
  projectId             String?
  reviewRunId           String?       @unique
  provider              AiProvider    @default(OPENAI)
  model                 String
  operation             String
  status                AiUsageStatus
  technicalInputTokens  Int           @default(0)
  technicalOutputTokens Int           @default(0)
  technicalTotalTokens  Int           @default(0)
  billedCredits         Int           @default(0)
  costEstimateUsd       Decimal?      @db.Decimal(10, 4)
  latencyMs             Int?
  requestHash           String?
  createdAt             DateTime      @default(now())
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project               Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  reviewRun             ReviewRun?    @relation(fields: [reviewRunId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  entityType  String
  entityId    String
  action      String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
}
