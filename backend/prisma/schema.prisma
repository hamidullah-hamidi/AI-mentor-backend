generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ProjectStatus {
  DRAFT
  IN_REVIEW
  READY
  ARCHIVED
}

enum ManuscriptType {
  CASE_REPORT
}

enum ProjectSectionKey {
  TITLE
  ABSTRACT
  KEYWORDS
  INTRODUCTION
  CASE_PRESENTATION
  DISCUSSION
  CONCLUSION
  PATIENT_PERSPECTIVE
  INFORMED_CONSENT
  REFERENCES
  COVER_LETTER
}

enum SectionStatus {
  NOT_STARTED
  DRAFT
  IN_REVIEW
  READY
}

enum ReviewRunStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  RESOLVED
  IGNORED
}

enum ReadinessStatus {
  NOT_READY
  NEEDS_ATTENTION
  READY_FOR_INTERNAL_REVIEW
  READY_FOR_SUBMISSION
}

enum GuidelinePackStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PromptTemplateType {
  SECTION_REVIEW
  SYSTEM_GUARDRAIL
  FOLLOW_UP
}

enum PromptTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PlanBillingModel {
  FREE
  MONTHLY
  CREDIT_PACK
  HYBRID
}

enum SubscriptionPlanStatus {
  ACTIVE
  ARCHIVED
}

enum UserSubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  TRIALING
}

enum CreditTransactionType {
  ALLOCATION
  DEDUCTION
  ADJUSTMENT
  EXPIRY
  REFUND
  PURCHASE
}

enum CreditTransactionSource {
  SUBSCRIPTION
  AI_REVIEW
  AI_PARAPHRASE
  ADMIN_ADJUSTMENT
  PURCHASE
  MANUAL
}

enum AiProvider {
  OPENAI
}

enum AiUsageStatus {
  SUCCESS
  FAILED
  SKIPPED
}

enum paraphraseRunStatuses {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  fullName           String
  role               Role                @default(USER)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  projects           Project[]
  refreshTokens      RefreshToken[]
  sectionVersions    SectionVersion[]
  initiatedReviews   ReviewRun[]         @relation("ReviewInitiator")
  resolvedIssues     ReviewIssue[]       @relation("IssueResolver")
  subscriptions      UserSubscription[]
  creditWallet       CreditWallet?
  creditTransactions CreditTransaction[]
  aiUsageLogs        AiUsageLog[]
  auditLogs          AuditLog[]          @relation("AuditActor")
  paraphraseRuns     ParaphraseRun[]     @relation("ParaphraseInitiator")

  @@index([role, isActive])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Project {
  id                 String              @id @default(cuid())
  ownerId            String
  manuscriptType     ManuscriptType      @default(CASE_REPORT)
  title              String
  status             ProjectStatus       @default(DRAFT)
  targetJournal      String?
  metadata           Json?
  readinessScore     Int?
  lastReviewedAt     DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  owner              User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sections           ProjectSection[]
  reviewRuns         ReviewRun[]
  reviewIssues       ReviewIssue[]
  readinessSnapshots ReadinessSnapshot[]
  aiUsageLogs        AiUsageLog[]
  paraphraseRuns     ParaphraseRun[]

  @@index([ownerId, updatedAt])
  @@index([status])
}

model ProjectSection {
  id             String            @id @default(cuid())
  projectId      String
  key            ProjectSectionKey
  title          String
  content        String            @default("")
  sectionOrder   Int
  isOptional     Boolean           @default(false)
  status         SectionStatus     @default(NOT_STARTED)
  lastEditedAt   DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions       SectionVersion[]
  reviewRuns     ReviewRun[]
  issues         ReviewIssue[]
  paraphraseRuns ParaphraseRun[]

  @@unique([projectId, key])
  @@index([projectId, sectionOrder])
}

model SectionVersion {
  id            String         @id @default(cuid())
  sectionId     String
  versionNumber Int
  content       String
  changeSummary String?
  editedById    String
  createdAt     DateTime       @default(now())
  section       ProjectSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  editedBy      User           @relation(fields: [editedById], references: [id], onDelete: Restrict)

  @@unique([sectionId, versionNumber])
  @@index([editedById, createdAt])
}

model ReviewRun {
  id                   String              @id @default(cuid())
  projectId            String
  sectionId            String
  initiatedById        String
  promptTemplateId     String?
  guidelinePackId      String?
  aiProvider           AiProvider          @default(OPENAI)
  aiModel              String
  status               ReviewRunStatus     @default(QUEUED)
  summary              String?
  nextSteps            Json?
  missingInfoQuestions Json?
  warnings             Json?
  overallScore         Int?
  readinessIndicator   Int?
  rawResponse          Json?
  errorMessage         String?
  inputTokens          Int?
  outputTokens         Int?
  totalTokens          Int?
  appCreditsConsumed   Int                 @default(0)
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  project              Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  section              ProjectSection      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  initiatedBy          User                @relation("ReviewInitiator", fields: [initiatedById], references: [id], onDelete: Restrict)
  issues               ReviewIssue[]
  suggestions          ReviewSuggestion[]
  metrics              ReviewMetric[]
  usageLog             AiUsageLog?
  promptTemplate       PromptTemplate?     @relation(fields: [promptTemplateId], references: [id], onDelete: SetNull)
  guidelinePack        GuidelinePack?      @relation(fields: [guidelinePackId], references: [id], onDelete: SetNull)
  creditTransactions   CreditTransaction[]

  @@index([projectId, createdAt])
  @@index([sectionId, createdAt])
  @@index([status])
}

model ReviewIssue {
  id            String         @id @default(cuid())
  reviewRunId   String
  projectId     String
  sectionId     String
  severity      IssueSeverity
  category      String
  title         String
  description   String
  reason        String
  fixSuggestion String
  status        IssueStatus    @default(OPEN)
  resolvedAt    DateTime?
  resolvedById  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  reviewRun     ReviewRun      @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  section       ProjectSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  resolvedBy    User?          @relation("IssueResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([projectId, status, severity])
  @@index([sectionId, status])
}

model ReviewSuggestion {
  id          String    @id @default(cuid())
  reviewRunId String
  type        String
  title       String
  content     String
  createdAt   DateTime  @default(now())
  reviewRun   ReviewRun @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)

  @@index([reviewRunId])
}

model ReviewMetric {
  id          String    @id @default(cuid())
  reviewRunId String
  name        String
  score       Int
  weight      Int?
  rationale   String?
  createdAt   DateTime  @default(now())
  reviewRun   ReviewRun @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)

  @@index([reviewRunId])
}

model ReadinessSnapshot {
  id            String          @id @default(cuid())
  projectId     String
  overallScore  Int
  status        ReadinessStatus
  summary       String
  blockers      Json?
  strengths     Json?
  sectionScores Json?
  createdAt     DateTime        @default(now())
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model GuidelinePack {
  id             String              @id @default(cuid())
  name           String
  code           String              @unique
  version        String
  description    String?
  manuscriptType ManuscriptType      @default(CASE_REPORT)
  status         GuidelinePackStatus @default(DRAFT)
  rules          Json
  isDefault      Boolean             @default(false)
  createdById    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  archivedAt     DateTime?
  reviewRuns     ReviewRun[]

  @@index([status, isDefault])
}

model PromptTemplate {
  id             String               @id @default(cuid())
  name           String
  code           String               @unique
  description    String?
  type           PromptTemplateType
  version        Int                  @default(1)
  status         PromptTemplateStatus @default(DRAFT)
  templateText   String
  responseSchema Json?
  config         Json?
  createdById    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  archivedAt     DateTime?
  reviewRuns     ReviewRun[]
  paraphraseRuns ParaphraseRun[]

  @@index([type, status])
}

model SubscriptionPlan {
  id                      String                 @id @default(cuid())
  name                    String
  code                    String                 @unique
  description             String?
  billingModel            PlanBillingModel
  monthlyPriceCents       Int?
  includedCredits         Int                    @default(0)
  overageCreditPriceCents Int?
  features                Json?
  status                  SubscriptionPlanStatus @default(ACTIVE)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  subscriptions           UserSubscription[]

  @@index([status, billingModel])
}

model UserSubscription {
  id                 String                 @id @default(cuid())
  userId             String
  subscriptionPlanId String
  status             UserSubscriptionStatus @default(ACTIVE)
  startedAt          DateTime               @default(now())
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  autoRenew          Boolean                @default(true)
  externalReference  String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionPlan   SubscriptionPlan       @relation(fields: [subscriptionPlanId], references: [id], onDelete: Restrict)

  @@index([userId, status, currentPeriodEnd])
}

model CreditWallet {
  id                      String              @id @default(cuid())
  userId                  String              @unique
  balance                 Int                 @default(0)
  lifetimeCreditsGranted  Int                 @default(0)
  lifetimeCreditsConsumed Int                 @default(0)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  user                    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions            CreditTransaction[]

  @@index([balance])
}

model CreditTransaction {
  id                     String                  @id @default(cuid())
  walletId               String
  userId                 String
  type                   CreditTransactionType
  source                 CreditTransactionSource
  amount                 Int
  balanceAfter           Int
  description            String?
  relatedReviewRunId     String?
  relatedParaphraseRunId String?
  metadata               Json?
  createdAt              DateTime                @default(now())
  wallet                 CreditWallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewRun              ReviewRun?              @relation(fields: [relatedReviewRunId], references: [id], onDelete: SetNull)
  paraphraseRun          ParaphraseRun?          @relation(fields: [relatedParaphraseRunId], references: [id])

  @@index([userId, createdAt])
  @@index([relatedReviewRunId])
  @@index([relatedParaphraseRunId])
}

model AiUsageLog {
  id                    String         @id @default(cuid())
  userId                String
  projectId             String?
  reviewRunId           String?        @unique
  paraphraseRunId       String?        @unique
  provider              AiProvider     @default(OPENAI)
  model                 String
  operation             String
  status                AiUsageStatus
  technicalInputTokens  Int            @default(0)
  technicalOutputTokens Int            @default(0)
  technicalTotalTokens  Int            @default(0)
  billedCredits         Int            @default(0)
  costEstimateUsd       Decimal?       @db.Decimal(10, 4)
  latencyMs             Int?
  requestHash           String?
  createdAt             DateTime       @default(now())
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project               Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  reviewRun             ReviewRun?     @relation(fields: [reviewRunId], references: [id], onDelete: SetNull)
  paraphraseRun         ParaphraseRun? @relation(fields: [paraphraseRunId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  entityType  String
  entityId    String
  action      String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
}

model ParaphraseRun {
  id                 String                @id @default(cuid())
  projectId          String
  sectionId          String
  initiatedById      String
  originalText       String
  paraphrasedText    String
  tone               String
  preservedWords     Json?
  lengthStrategy     String?
  changes            Json?
  metrics            Json?
  aiProvider         AiProvider            @default(OPENAI)
  grammarTips        Json?
  status             paraphraseRunStatuses @default(QUEUED)
  aiModel            String
  promptTemplateId   String?
  rawResponse        Json?
  errorMessage       String?
  inputTokens        Int?
  outputTokens       Int?
  totalTokens        Int?
  appCreditsConsumed Float                 @default(0)
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  project            Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  section            ProjectSection        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  initiatedBy        User                  @relation("ParaphraseInitiator", fields: [initiatedById], references: [id], onDelete: Restrict)
  creditTransactions CreditTransaction[]
  promptTemplate     PromptTemplate?       @relation(fields: [promptTemplateId], references: [id], onDelete: SetNull)
  aiUsageLog         AiUsageLog?

  @@index([projectId, createdAt])
  @@index([sectionId, createdAt])
}
